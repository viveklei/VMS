# --- BUILD STAGE ---
FROM node:20-alpine AS build
WORKDIR /app
COPY backend/package*.json ./
RUN npm ci
COPY backend/ ./
RUN npm run build

# --- PRODUCTION STAGE ---
FROM node:20-alpine AS production
WORKDIR /app
COPY backend/package*.json ./
RUN npm ci --only=production
COPY --from=build /app/dist ./dist
COPY backend/.env* ./

ENV PORT=5000
ENV NODE_ENV=production

EXPOSE 5000
CMD ["node", "dist/app.js"]
